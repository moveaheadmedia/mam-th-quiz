            "all_ranked": "={{ $json.all_ranked }}",
            "recaptcha_configured": "={{ $json.recaptcha_configured }}",
            "recaptcha_success": "={{ $json.recaptcha_success }}",
            "recaptcha_score": "={{ $json.recaptcha_score }}",
            "client_spam_score": "={{ $json.client_spam_score }}",
