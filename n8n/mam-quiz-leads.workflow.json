      "id": "insert-lead-row",
      "name": "Insert lead row",
      "type": "n8n-nodes-base.dataTable",
      "typeVersion": 1.1,
      "position": [560, 860]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "{\n  \"ok\": true\n}",
        "options": {
          "responseCode": 200
        }
      },
      "id": "respond-ok",
      "name": "Respond to quiz",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.5,
      "position": [800, 860]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 2
          },
          "conditions": [
            {
              "id": "cond-review",
              "leftValue": "={{ $('Build lead row').item.json.status }}",
              "rightValue": "review",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "needs-review",
      "name": "Needs review?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [1040, 860]
    },
    {
      "parameters": {},
      "id": "branch-review",
      "name": "Review queue",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [1300, 740],
      "notesInFlow": true,
      "notes": "Flagged — alert a human, do not auto-bin"
    },
    {
